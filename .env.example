# Astrololo Environment Variables

# Swiss Ephemeris Configuration (optional)
SE_EPHE_PATH=/path/to/ephe

# AI Configuration (optional - for enhanced interpretation)
# Set ASTRO_AI_API_KEY to enable AI interpretation
# Choose between 'openai' or 'ollama' provider
ASTRO_AI_PROVIDER=openai
ASTRO_AI_MODEL=gpt-4o-mini
ASTRO_AI_MAX_TOKENS=1024
ASTRO_AI_TEMPERATURE=0.7
# For OpenAI
ASTRO_AI_API_KEY=your-openai-api-key-here
# For Ollama
ASTRO_AI_ENDPOINT=http://localhost:11434/api/chat

# Server Configuration
# Host to bind the server to
HOST=0.0.0.0
# Port to listen on
PORT=8000
# Enable debug mode (true/false)
DEBUG=false

# Logging
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
